# Copy to .env.local and fill in. Create React App only exposes REACT_APP_* vars.
# Find these under Supabase → Project Settings → API. The anon key is safe in the
# browser; row-level security keeps the subscriptions table locked down.
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
