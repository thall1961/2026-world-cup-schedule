# Copy to .env.local and fill in. Create React App only exposes REACT_APP_* vars.
# Find these under Supabase → Project Settings → API.
#
# Use the browser-safe key: the "publishable key" (sb_publishable_...) in the
# current dashboard, or the legacy "anon" JWT (eyJ...) on older projects — either
# works. NEVER use the secret/service_role key here; it bypasses row-level
# security. RLS keeps the subscriptions table locked down regardless.
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Google Analytics 4 measurement ID (Admin → Data Streams → your web stream).
# Leave blank to disable analytics entirely (no gtag script is loaded).
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX
